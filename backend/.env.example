# =========================
# Application
# =========================
APP_HOST=0.0.0.0
APP_PORT=6522
CORS_ORIGINS=http://localhost:5569
MAX_UPLOAD_MB=10  # 简历文件最高 10 MB

# =========================
# OCR API 可选，智谱 OCR，
# =========================
# ZHIPU_APIKEY=your-zhipu-api-key

# =========================
# LLM 配置 必选
# =========================
MODEL_PROVIDER=openai

# OpenAI / OpenAI-Compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=



# Speech-to-Text 可选 
# nostream: bigmodel_nostream，停止后返回最终结果；streaming: bigmodel，实时返回；streaming_async: bigmodel_async，优化版实时返回
# VOLCENGINE_SPEECH_BASE_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
# VOLCENGINE_SPEECH_MODE=nostream
# VOLCENGINE_SPEECH_APP_KEY=your-volcengine-app-key
# VOLCENGINE_SPEECH_ACCESS_KEY=your-volcengine-access-key
# VOLCENGINE_SPEECH_RESOURCE_ID=volc.bigasr.sauc.duration

# =========================
# Rate Limiter
# =========================
RATE_LIMIT_REQUESTS_PER_SECOND=0.1 # rpm 6
RATE_LIMIT_CHECK_EVERY_N_SECONDS=0.1 # 0.1秒检查一次请求队列
RATE_LIMIT_MAX_BUCKET_SIZE=5 # 一次请求最多允许的积压请求数，超过则直接拒绝

# =========================
# Interview data
# =========================
INTERVIEW_DB_PATH=data/interviews.db # SQLite 数据库文件路径
INTERVIEW_ZVEC_INDEX_PATH=data/interview_zvec # Zvec 向量索引文件路径

# =========================
# Mock interview RAG（可选能力）
# 详细说明见：backend/docs/rag-config.md
# 安装层（local）：执行 uv sync --extra rag
# 安装层（Docker）：在 docker compose build/up --build 前提供 BACKEND_INSTALL_RAG=true
# 运行时层：backend/.env 中的 MOCK_INTERVIEW_RAG 只控制容器 / 进程启动后的开关，不参与镜像构建
# =========================
# true  = 运行时尝试开启 RAG 检索
# false = 运行时关闭 RAG，仅使用 non-RAG fallback / LLM 生成，默认关闭
# 注意：就算写成 true，若未安装 rag 可选依赖、镜像未以 BACKEND_INSTALL_RAG=true 构建，或相关依赖不可用，后端仍会自动回退到 non-RAG
MOCK_INTERVIEW_RAG=false

# 仅影响召回数量和 dense/sparse 重排权重；通常保持默认即可
INTERVIEW_RAG_TOPK=5
INTERVIEW_RAG_CANDIDATE_TOPK=12
INTERVIEW_RAG_DENSE_WEIGHT=1.2
INTERVIEW_RAG_SPARSE_WEIGHT=1.0

# 当前 .env.example 只保留推荐方案示例：local_hf_qwen3 + bm25
# 如果你要切换到其他 provider 组合，请查看 backend/docs/rag-config.md
# 切换 index-side embedding 配置后，需要先安装 rag 可选依赖，再重建 backend/data/interview_zvec

# Dense: local_hf_qwen3
INTERVIEW_DENSE_EMBEDDING_PROVIDER=local_hf_qwen3
INTERVIEW_DENSE_EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
INTERVIEW_DENSE_EMBEDDING_MODEL_SOURCE=huggingface
INTERVIEW_DENSE_EMBEDDING_DEVICE=cpu
INTERVIEW_DENSE_EMBEDDING_NORMALIZE=true

# Sparse: bm25
INTERVIEW_SPARSE_EMBEDDING_PROVIDER=bm25
INTERVIEW_SPARSE_EMBEDDING_LANGUAGE=zh

